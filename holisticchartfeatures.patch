+<% content_for :title, "Book #{@service.name}" %>
+
+<div class="mb-3">
+  <%= link_to service_path(@service), class: "text-muted text-decoration-none small" do %><i class="fa-solid fa-chevron-left me-1"></i> Back to <%= @service.name %><% end %>
+</div>
+
+<div class="section-head">
+  <div>
+    <span class="eyebrow"><%= @service.category %></span>
+    <h1 class="h3 mb-0">Request your session</h1>
+  </div>
+</div>
+
+<div class="hwf-card" style="max-width: 720px;">
+  <div class="d-flex align-items-center gap-3 mb-4">
+    <div class="service-icon-lg" style="background: <%= @service.accent %>;"><i class="fa-solid <%= @service.icon_name %>"></i></div>
+    <div>
+      <div class="fw-bold"><%= @service.name %></div>
+      <div class="small text-muted"><%= @service.duration_min %> min · <%= @service.price %></div>
+    </div>
+  </div>
+
+  <%= form_with model: @appointment, local: true do |f| %>
+    <% if @appointment.errors.any? %>
+      <div class="alert alert-danger">
+        <ul class="mb-0"><% @appointment.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
+      </div>
+    <% end %>
+
+    <%= f.hidden_field :service_id, value: @service.id %>
+
+    <div class="row g-3">
+      <div class="col-md-6">
+        <%= f.label :scheduled_at, "Preferred date & time", class: "form-label" %>
+        <%= f.datetime_field :scheduled_at, class: "form-control", min: Time.current.strftime("%Y-%m-%dT%H:%M") %>
+      </div>
+      <div class="col-md-6">
+        <span class="form-label d-block">Format</span>
+        <div class="btn-group w-100" role="group">
+          <%= f.radio_button :mode, "in_person", class: "btn-check", id: "mode_in_person" %>
+          <%= f.label "mode_in_person", class: "btn btn-outline-brand" do %><i class="fa-solid fa-location-dot me-1"></i> In person<% end %>
+          <%= f.radio_button :mode, "virtual", class: "btn-check", id: "mode_virtual" %>
+          <%= f.label "mode_virtual", class: "btn btn-outline-brand" do %><i class="fa-solid fa-video me-1"></i> Virtual<% end %>
+        </div>
+      </div>
+      <div class="col-12">
+        <%= f.label :reason, "What would you like to focus on? (optional)", class: "form-label" %>
+        <%= f.text_area :reason, rows: 3, class: "form-control", placeholder: "Goals, injuries, questions…" %>
+      </div>
+    </div>
+
+    <div class="d-flex gap-2 mt-4">
+      <%= f.submit "Request session", class: "btn btn-brand" %>
+      <%= link_to "Cancel", services_path, class: "btn btn-outline-brand" %>
+    </div>
+    <p class="field-hint mt-3"><i class="fa-solid fa-circle-info me-1"></i>You'll get a confirmation once the care team approves your time. Virtual sessions include a meeting link.</p>
+  <% end %>
+</div>

+            <h2 class="h5 mb-0 mt-1"><%= service.name %></h2>
+          </div>
+        </div>
+        <p class="text-muted flex-fill"><%= service.tagline %></p>
+        <div class="d-flex justify-content-between align-items-center text-muted small mb-3">

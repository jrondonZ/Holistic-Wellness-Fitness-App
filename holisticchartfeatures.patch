+<% content_for :title, "Appointments" %>
+
+<div class="section-head">
+  <div>
+    <span class="eyebrow">Meet &amp; scheduling</span>
+    <h1 class="h3 mb-0">My appointments</h1>
+  </div>
+  <%= link_to services_path, class: "btn btn-brand" do %><i class="fa-solid fa-plus me-1"></i> Book a session<% end %>
+</div>
+
+<h2 class="h6 card-title-sm mb-3">Upcoming</h2>
+<% if @upcoming.any? %>
+  <div class="d-flex flex-column gap-2 mb-4">
+    <% @upcoming.each do |appt| %>
+      <div class="appt-card">
+        <div class="appt-date">
+          <div class="d"><%= appt.scheduled_at.strftime("%-d") %></div>
+          <div class="m"><%= appt.scheduled_at.strftime("%b") %></div>
+        </div>
+        <div class="flex-fill">
+          <div class="fw-bold"><%= appt.service.name %></div>
+          <div class="small text-muted">
+            <%= appt.scheduled_at.strftime("%A · %-l:%M %p") %> · <%= appt.mode_label %>
+            <% if appt.virtual? && appt.meeting_url.present? %>
+              · <%= link_to "Join link", appt.meeting_url, target: "_blank", rel: "noopener", class: "text-brand" %>
+            <% end %>
+          </div>
+        </div>
+        <span class="pill <%= appt.status_tone %>"><%= appt.status.titleize %></span>
+        <div class="d-flex gap-2">
+          <%= link_to '<i class="fa-regular fa-calendar-plus"></i>'.html_safe, calendar_appointment_path(appt), class: "btn btn-soft btn-sm", title: "Add to calendar" %>
+          <%= link_to "Details", appointment_path(appt), class: "btn btn-soft btn-sm" %>
+        </div>
+      </div>
+    <% end %>
+  </div>
+<% else %>
+  <div class="hwf-card empty-state mb-4">
+    <div class="icon"><i class="fa-solid fa-calendar-day"></i></div>
+    <p class="mb-3">No upcoming sessions. Book personal training, nutrition, pelvic health, boxing or kids athletics.</p>
+    <%= link_to "Browse services", services_path, class: "btn btn-brand" %>
+  </div>
+<% end %>
+
+<% if @past.any? %>
+  <h2 class="h6 card-title-sm mb-3">History</h2>
+  <div class="hwf-card">
+    <div class="table-scroll">
+      <table class="flowsheet">
+        <thead><tr><th>Date</th><th>Service</th><th>Format</th><th>Status</th></tr></thead>
+        <tbody>
+          <% @past.each do |appt| %>
+            <tr>
+              <td class="fw-semibold"><%= appt.scheduled_at.strftime("%b %-d, %Y") %></td>
+              <td><%= link_to appt.service.name, appointment_path(appt), class: "text-decoration-none" %></td>
+              <td><%= appt.mode_label %></td>
+              <td><span class="pill <%= appt.status_tone %>"><%= appt.status.titleize %></span></td>
+            </tr>
+          <% end %>
+        </tbody>
+      </table>
+    </div>
+  </div>
+<% end %>

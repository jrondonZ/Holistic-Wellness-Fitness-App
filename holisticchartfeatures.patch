--- /dev/null
+++ b/app/views/trainings/index.html.erb
@@ -0,0 +1,46 @@
+<% content_for :title, "Training" %>
+
+<div class="section-head">
+  <div>
+    <span class="eyebrow">Compliance &amp; education</span>
+    <h1 class="h3 mb-0">Required training</h1>
+  </div>
+</div>
+
+<% if @trainings.any? %>
+  <div class="row g-3">
+    <% @trainings.each do |t| %>
+      <% completion = @completions[t.id] %>
+      <% done = completion&.acknowledged? %>
+      <div class="col-md-6">
+        <div class="hwf-card is-hover h-100">
+          <div class="d-flex justify-content-between align-items-start mb-2">
+            <div class="service-icon-lg" style="background: <%= done ? 'var(--brand-green)' : 'var(--brand-gold)' %>; width:48px; height:48px; font-size:1.2rem;">
+              <i class="fa-solid <%= done ? 'fa-circle-check' : 'fa-shield-halved' %>"></i>
+            </div>
+            <% if done %>
+              <span class="pill good"><i class="fa-solid fa-check me-1"></i>Completed</span>
+            <% elsif t.required %>
+              <span class="pill low">Required</span>
+            <% end %>
+          </div>
+          <h2 class="h5"><%= t.title %></h2>
+          <p class="text-muted"><%= t.summary %></p>
+          <div class="d-flex justify-content-between align-items-center mt-3">
+            <span class="small text-muted"><i class="fa-regular fa-clock me-1"></i><%= t.minutes %> min<%= " · v#{t.version}" if t.version.present? %></span>
+            <% if done %>
+              <%= link_to "Review", training_path(t), class: "btn btn-soft btn-sm" %>
+            <% else %>
+              <%= link_to "Start training", training_path(t), class: "btn btn-brand btn-sm" %>
+            <% end %>
+          </div>
+          <% if done && completion.completed_at %>
+            <div class="field-hint mt-2">Completed <%= completion.completed_at.strftime("%b %-d, %Y") %><%= " · #{completion.score}%" if completion.score %></div>
+          <% end %>
+        </div>
+      </div>
+    <% end %>
+  </div>
+<% else %>
+  <div class="hwf-card empty-state"><div class="icon"><i class="fa-solid fa-shield-halved"></i></div><p class="mb-0">No training assigned right now.</p></div>
+<% end %>
diff --git a/app/views/trainings/show.html.erb b/app/views/trainings/show.html.erb
new file mode 100644
index 0000000..3ee54ca
--- /dev/null
+++ b/app/views/trainings/show.html.erb
@@ -0,0 +1,75 @@
+<% content_for :title, @training.title %>
+
+<div class="mb-3">
+  <%= link_to trainings_path, class: "text-muted text-decoration-none small" do %><i class="fa-solid fa-chevron-left me-1"></i> All training<% end %>
+</div>
+
+<% if @completion&.acknowledged? %>
+  <div class="hwf-card text-center mb-4" style="background: var(--brand-green-soft); border: none;">
+    <div class="cert-badge mb-2"><i class="fa-solid fa-certificate"></i></div>
+    <h2 class="h5 mb-1">Training complete</h2>
+    <p class="mb-0 text-muted">
+      <%= current_user.full_name %> completed <strong><%= @training.title %></strong>
+      on <%= @completion.completed_at&.strftime("%B %-d, %Y") %><%= " · scored #{@completion.score}%" if @completion.score %>.
+    </p>
+  </div>
+<% end %>
+
+<div class="row g-4">
+  <div class="col-lg-8">
+    <article class="hwf-card p-4 p-md-5">
+      <span class="pill gold">HIPAA &amp; Privacy</span>
+      <h1 class="h3 mt-3"><%= @training.title %></h1>
+      <p class="lead text-muted"><%= @training.summary %></p>
+      <hr class="my-4">
+      <div class="article-body">
+        <% @training.sections.each do |para| %>
+          <% if para.start_with?("## ") %>
+            <h2 class="h5 mt-4"><%= para.delete_prefix("## ") %></h2>
+          <% else %>
+            <p><%= para %></p>
+          <% end %>
+        <% end %>
+      </div>
+    </article>
+  </div>
+
+  <div class="col-lg-4">
+    <div class="hwf-card" style="position: sticky; top: 84px;">
+      <h2 class="h6 card-title-sm mb-3"><i class="fa-solid fa-clipboard-check me-1"></i> Acknowledge &amp; sign</h2>
+
+      <%= form_with url: complete_training_path(@training), method: :post, local: true do %>
+        <% if @training.quiz? %>
+          <div class="mb-3">
+            <div class="fw-semibold mb-2">Knowledge check</div>
+            <p class="field-hint mb-3">Score <%= TrainingModule::PASS_THRESHOLD %>%+ to pass.</p>
+            <% @training.questions.each_with_index do |q, i| %>
+              <div class="mb-3">
+                <div class="fw-semibold mb-2"><span class="training-step me-1"><%= i + 1 %></span> <%= q["q"] %></div>
+                <% Array(q["options"]).each_with_index do |opt, oi| %>
+                  <label class="quiz-option">
+                    <%= radio_button_tag "answers[#{i}]", oi, false, required: true %><%= opt %>
+                  </label>
+                <% end %>
+              </div>
+            <% end %>
+            <hr class="my-3">
+          <% end %>
+
+        <label class="d-flex gap-2 align-items-start mb-3">
+          <%= check_box_tag :acknowledge, "1", false, class: "form-check-input mt-1", required: true %>
+          <span class="small">I confirm I have read and understood this training, and I will protect members' health information accordingly.</span>
+        </label>
+
+        <div class="mb-3">
+          <%= label_tag :signature, "Type your full name to sign", class: "form-label" %>
+          <%= text_field_tag :signature, current_user.full_name, class: "form-control", required: true %>
+        </div>
+
+        <div class="d-grid">
+          <%= submit_tag(@completion&.acknowledged? ? "Re-submit" : "Complete training", class: "btn btn-brand") %>
+        </div>
+      <% end %>
+    </div>
+  </div>
+</div>
diff --git a/config/routes.rb b/config/routes.rb

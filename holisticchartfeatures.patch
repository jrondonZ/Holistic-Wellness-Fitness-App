+      @q = params[:q].to_s.strip
+      scope = User.members.order(created_at: :desc)
+      if @q.present?
+        like = "%#{@q.downcase}%"
+        scope = scope.where("lower(first_name) LIKE ? OR lower(last_name) LIKE ? OR lower(email) LIKE ? OR lower(username) LIKE ?",

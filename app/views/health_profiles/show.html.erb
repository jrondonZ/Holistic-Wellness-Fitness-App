<% content_for :title, "My details" %>
<% weight = current_user.current_weight %>

<div class="section-head">
  <div>
    <span class="eyebrow">Chart</span>
    <h1 class="h3 mb-0">My details</h1>
  </div>
  <%= link_to edit_health_profile_path, class: "btn btn-brand" do %><i class="fa-solid fa-pen me-1"></i> Edit details<% end %>
</div>

<!-- Identity banner -->
<div class="patient-banner mb-4">
  <div class="d-flex align-items-center gap-3">
    <%= initials_badge(current_user, extra_class: "lg") %>
    <div>
      <h1><%= current_user.full_name %></h1>
      <div class="patient-meta mt-1">
        <span><%= current_user.member_id %></span>
        <% if @profile.age %><span class="sep">·</span><span><%= @profile.age %> yrs</span><% end %>
        <% if @profile.sex.present? %><span class="sep">·</span><span><%= @profile.sex %></span><% end %>
        <% if @profile.blood_type.present? %><span class="sep">·</span><span>Blood <%= @profile.blood_type %></span><% end %>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <!-- Goal progress -->
  <div class="col-lg-4">
    <div class="hwf-card h-100 text-center">
      <div class="card-title-sm">Goal progress</div>
      <% progress = @profile.goal_progress %>
      <div class="stat-value my-2" style="font-size:2.6rem;"><%= progress ? "#{progress}%" : "—" %></div>
      <% if progress %>
        <div class="hwf-progress mb-3"><span style="width: <%= progress %>%"></span></div>
        <div class="d-flex justify-content-between small text-muted">
          <span>Start <%= @profile.starting_weight&.to_f&.round %> lb</span>
          <span>Now <%= weight&.to_f&.round %> lb</span>
          <span>Goal <%= @profile.goal_weight&.to_f&.round %> lb</span>
        </div>
      <% else %>
        <p class="text-muted small">Add starting &amp; goal weights to track progress.</p>
      <% end %>
    </div>
  </div>

  <!-- Vitals snapshot -->
  <div class="col-lg-8">
    <div class="hwf-card h-100">
      <div class="card-title-sm mb-3">Snapshot</div>
      <div class="row g-3">
        <% {
          "Height" => @profile.height_display, "Current weight" => (weight ? "#{weight.to_f.round} lb" : nil),
          "BMI" => (@profile.bmi ? "#{@profile.bmi} (#{@profile.bmi_category})" : nil),
          "Daily target" => "#{number_with_delimiter @profile.target_calories} kcal",
          "Primary goal" => @profile.primary_goal, "Activity" => @profile.activity_level,
          "Diet" => @profile.dietary_preference, "Coach" => @profile.coach
        }.each do |label, value| %>
          <div class="col-6 col-md-3">
            <div class="card-title-sm"><%= label %></div>
            <div class="fw-bold"><%= value.presence || "—" %></div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- History -->
  <div class="col-12">
    <div class="hwf-card">
      <div class="card-title-sm mb-3">Care &amp; history</div>
      <div class="row g-4">
        <div class="col-md-6">
          <div class="text-muted small mb-1">Allergies / sensitivities</div>
          <p class="mb-0"><%= @profile.allergies.presence || "None recorded." %></p>
        </div>
        <div class="col-md-6">
          <div class="text-muted small mb-1">Conditions / notes</div>
          <p class="mb-0"><%= @profile.conditions.presence || "None recorded." %></p>
        </div>
        <div class="col-md-6">
          <div class="text-muted small mb-1">Emergency contact</div>
          <p class="mb-0"><%= @profile.emergency_contact.presence || "Not provided." %></p>
        </div>
        <div class="col-md-6">
          <div class="text-muted small mb-1">Member since</div>
          <p class="mb-0"><%= current_user.created_at.strftime("%B %-d, %Y") %></p>
        </div>
      </div>
    </div>
  </div>
</div>

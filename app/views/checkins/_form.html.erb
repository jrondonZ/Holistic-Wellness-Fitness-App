<%= form_with model: checkin, local: true do |f| %>
  <% if checkin.errors.any? %>
    <div class="alert alert-danger">
      <strong><i class="fa-solid fa-circle-exclamation me-1"></i> Please fix:</strong>
      <ul class="mb-0 mt-1"><% checkin.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>

  <div class="mb-4" style="max-width: 240px;">
    <%= f.label :checkin_date, "Date", class: "form-label" %>
    <%= f.date_field :checkin_date, class: "form-control" %>
  </div>

  <div class="row g-4">
    <div class="col-md-4">
      <label class="form-label d-block">Mood</label>
      <%= scale_field(f, :mood, Checkin::MOOD_LABELS) %>
    </div>
    <div class="col-md-4">
      <label class="form-label d-block">Energy</label>
      <%= scale_field(f, :energy, Checkin::ENERGY_LABELS) %>
    </div>
    <div class="col-md-4">
      <label class="form-label d-block">Stress</label>
      <%= scale_field(f, :stress, Checkin::STRESS_LABELS) %>
    </div>
  </div>

  <hr class="my-4">
  <h2 class="card-title-sm mb-3"><i class="fa-solid fa-notes-medical me-1"></i> Vitals &amp; measurements</h2>
  <div class="row g-3">
    <div class="col-6 col-md-3">
      <%= f.label :sleep_hours, "Sleep (hrs)", class: "form-label" %>
      <%= f.number_field :sleep_hours, step: 0.5, min: 0, max: 24, class: "form-control", placeholder: "7.5" %>
    </div>
    <div class="col-6 col-md-3">
      <%= f.label :water_oz, "Water (oz)", class: "form-label" %>
      <%= f.number_field :water_oz, min: 0, class: "form-control", placeholder: "64" %>
    </div>
    <div class="col-6 col-md-3">
      <%= f.label :weight, "Weight (lb)", class: "form-label" %>
      <%= f.number_field :weight, step: 0.1, min: 0, class: "form-control", placeholder: "165" %>
    </div>
    <div class="col-6 col-md-3">
      <%= f.label :resting_hr, "Resting HR", class: "form-label" %>
      <%= f.number_field :resting_hr, min: 0, class: "form-control", placeholder: "62" %>
    </div>
    <div class="col-6 col-md-3">
      <%= f.label :systolic, "BP systolic", class: "form-label" %>
      <%= f.number_field :systolic, min: 0, class: "form-control", placeholder: "118" %>
    </div>
    <div class="col-6 col-md-3">
      <%= f.label :diastolic, "BP diastolic", class: "form-label" %>
      <%= f.number_field :diastolic, min: 0, class: "form-control", placeholder: "76" %>
    </div>
  </div>

  <div class="mt-3">
    <%= f.label :notes, "Notes", class: "form-label" %>
    <%= f.text_area :notes, rows: 3, class: "form-control", placeholder: "How did today feel? Anything notable for your gut, mood or body?" %>
  </div>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit submit_label, class: "btn btn-brand" %>
    <%= link_to "Cancel", checkins_path, class: "btn btn-outline-brand" %>
  </div>
<% end %>

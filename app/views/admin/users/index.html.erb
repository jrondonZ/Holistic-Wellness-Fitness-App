<% content_for :title, "Admin · Users" %>

<div class="section-head">
  <div>
    <span class="eyebrow">Admin portal</span>
    <h1 class="h3 mb-0"><%= current_user.owner? ? "All users" : "Members" %> <span class="text-muted fs-6">(<%= @users.size %>)</span></h1>
  </div>
  <div class="d-flex gap-2">
    <%= form_with url: admin_users_path, method: :get, local: true, class: "d-flex gap-2" do %>
      <%= text_field_tag :q, @q, class: "form-control form-control-sm", placeholder: "Search…" %>
      <%= submit_tag "Search", class: "btn btn-soft btn-sm" %>
    <% end %>
    <% if current_user.owner? %>
      <%= link_to new_admin_user_path, class: "btn btn-brand btn-sm" do %><i class="fa-solid fa-user-plus me-1"></i> New<% end %>
    <% end %>
  </div>
</div>

<div class="hwf-card">
  <% if @users.any? %>
    <div class="table-scroll">
      <table class="flowsheet">
        <thead>
          <tr><th>User</th><th>Role</th><th>ID</th><th>Check-ins</th><th>Last seen</th><th>Joined</th><th></th></tr>
        </thead>
        <tbody>
          <% @users.each do |u| %>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <%= initials_badge(u) %>
                  <div>
                    <div class="fw-semibold text-dark"><%= u.full_name %></div>
                    <div class="small text-muted"><%= u.email %></div>
                  </div>
                </div>
              </td>
              <td><span class="pill <%= u.owner? ? 'gold' : (u.staff? ? 'good' : 'muted') %>"><%= u.role_label %></span></td>
              <td class="small text-muted"><%= u.member? ? u.member_id : "—" %></td>
              <td><%= u.member? ? @checkin_counts[u.id].to_i : "—" %></td>
              <td class="small text-muted"><%= @last_checkin[u.id]&.strftime("%b %-d") || "—" %></td>
              <td class="small text-muted"><%= u.created_at.strftime("%b %-d, %Y") %></td>
              <td class="text-end">
                <% if u.member? %><%= link_to "Chart", admin_user_path(u), class: "btn btn-soft btn-sm" %><% end %>
                <% if current_user.owner? %><%= link_to "Edit", edit_admin_user_path(u), class: "btn btn-soft btn-sm" %><% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="empty-state"><div class="icon"><i class="fa-solid fa-users"></i></div><p class="mb-0">No users found.</p></div>
  <% end %>
</div>

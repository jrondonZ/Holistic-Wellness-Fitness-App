<%= form_with model: [ :admin, user ], local: true do |f| %>
  <% if user.errors.any? %>
    <div class="alert alert-danger"><ul class="mb-0"><% user.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul></div>
  <% end %>
  <div class="row g-3">
    <div class="col-md-6"><%= f.label :first_name, class: "form-label" %><%= f.text_field :first_name, class: "form-control", required: true %></div>
    <div class="col-md-6"><%= f.label :last_name, class: "form-label" %><%= f.text_field :last_name, class: "form-control", required: true %></div>
    <div class="col-md-6"><%= f.label :username, class: "form-label" %><%= f.text_field :username, class: "form-control", required: true %></div>
    <div class="col-md-6"><%= f.label :email, class: "form-label" %><%= f.email_field :email, class: "form-control", required: true %></div>
    <div class="col-md-6"><%= f.label :title, "Title / specialty", class: "form-label" %><%= f.text_field :title, class: "form-control", placeholder: "e.g. Nutrition Coach" %></div>
    <div class="col-md-6"><%= f.label :phone, class: "form-label" %><%= f.telephone_field :phone, class: "form-control" %></div>
    <div class="col-md-6">
      <%= f.label :role, "Role", class: "form-label" %>
      <% if user.owner? %>
        <div><span class="pill gold"><i class="fa-solid fa-crown me-1"></i>Owner — locked</span></div>
      <% else %>
        <%= f.select :role, [ [ "Member", "member" ], [ "Admin", "admin" ] ], {}, class: "form-select" %>
      <% end %>
    </div>
    <div class="col-12"><hr class="my-1"><div class="card-title-sm">Password <%= "(leave blank to keep current)" unless user.new_record? %></div></div>
    <div class="col-md-6"><%= f.label :password, class: "form-label" %><%= f.password_field :password, class: "form-control", autocomplete: "new-password", required: user.new_record? %></div>
    <div class="col-md-6"><%= f.label :password_confirmation, "Confirm", class: "form-label" %><%= f.password_field :password_confirmation, class: "form-control", autocomplete: "new-password", required: user.new_record? %></div>
  </div>
  <div class="d-flex gap-2 mt-4">
    <%= f.submit submit_label, class: "btn btn-brand" %>
    <%= link_to "Cancel", admin_users_path, class: "btn btn-outline-brand" %>
  </div>
<% end %>

<% content_for :title, @article.title %>

<div class="mb-3">
  <%= link_to articles_path, class: "text-muted text-decoration-none small" do %><i class="fa-solid fa-chevron-left me-1"></i> Back to library<% end %>
</div>

<div class="row g-4 justify-content-center">
  <div class="col-lg-8">
    <article class="hwf-card p-4 p-md-5">
      <span class="pill gold"><%= @article.category %></span>
      <h1 class="h2 mt-3"><%= @article.title %></h1>
      <div class="d-flex align-items-center gap-3 text-muted small mb-4">
        <span><i class="fa-solid fa-user-nurse me-1"></i><%= @article.author_name %></span>
        <span><i class="fa-regular fa-clock me-1"></i><%= @article.read_time %></span>
        <% if @article.published_on %><span><i class="fa-regular fa-calendar me-1"></i><%= @article.published_on.strftime("%B %Y") %></span><% end %>
      </div>

      <% if @article.summary.present? %>
        <p class="lead" style="color: var(--brand-green-dark);"><%= @article.summary %></p>
        <hr class="my-4">
      <% end %>

      <div class="article-body">
        <% @article.paragraphs.each do |para| %>
          <% if para.start_with?("## ") %>
            <h2 class="h4 mt-4"><%= para.delete_prefix("## ") %></h2>
          <% else %>
            <p><%= para %></p>
          <% end %>
        <% end %>
      </div>

      <div class="mt-4 p-3 rounded" style="background: var(--brand-green-soft);">
        <i class="fa-solid fa-leaf text-brand me-2"></i>
        <span class="small">Educational content from Holistic Wellness Fitness LLC. Always consult your own clinician before changing your care.</span>
      </div>
    </article>
  </div>

  <div class="col-lg-4">
    <div class="hwf-card">
      <div class="card-title-sm mb-2">More on <%= @article.category %></div>
      <% if @more.any? %>
        <% @more.each do |m| %>
          <%= link_to article_path(m), class: "d-block py-2 text-decoration-none border-bottom" do %>
            <div class="fw-semibold text-dark small"><%= m.title %></div>
            <div class="small text-muted"><%= m.read_time %></div>
          <% end %>
        <% end %>
      <% else %>
        <p class="text-muted small mb-0">More articles coming soon.</p>
      <% end %>
      <%= link_to "All articles", articles_path, class: "btn btn-soft btn-sm w-100 mt-3" %>
    </div>
  </div>
</div>

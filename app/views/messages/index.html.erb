<% content_for :title, "Messages" %>

<div class="section-head">
  <div>
    <span class="eyebrow">Secure messaging</span>
    <h1 class="h3 mb-0">Your providers</h1>
  </div>
  <span class="pill good"><i class="fa-solid fa-lock me-1"></i>Private &amp; secure</span>
</div>

<p class="text-muted">Choose a provider to message. Only you and that provider can see your conversation — messages are never shared with other members.</p>

<div class="row g-3">
  <% @threads.each do |t| %>
    <% provider = t[:provider] %>
    <div class="col-md-6">
      <%= link_to message_thread_path(provider), class: "hwf-card is-hover h-100 d-block text-decoration-none" do %>
        <div class="d-flex align-items-center gap-3">
          <%= initials_badge(provider, extra_class: "lg") %>
          <div class="flex-fill min-w-0">
            <div class="d-flex justify-content-between align-items-start">
              <div class="fw-bold text-dark"><%= provider.full_name %>
                <% if provider.owner? %><span class="pill gold ms-1" style="font-size:.6rem;">Owner</span><% end %>
              </div>
              <% if t[:unread].positive? %><span class="nav-badge" style="margin-left:0;"><%= t[:unread] %></span><% end %>
            </div>
            <div class="small text-muted"><%= provider.title.presence || "Care team" %></div>
            <div class="small text-muted text-truncate mt-1">
              <% if t[:last] %>
                <%= t[:last].from_member? ? "You: " : "" %><%= truncate(t[:last].body, length: 56) %>
              <% else %>
                <span class="fst-italic">No messages yet — say hello</span>
              <% end %>
            </div>
          </div>
          <i class="fa-solid fa-chevron-right text-muted"></i>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<% if @threads.empty? %>
  <div class="hwf-card empty-state">
    <div class="icon"><i class="fa-solid fa-user-doctor"></i></div>
    <p class="mb-0">No providers are available to message yet. Your care team will be assigned shortly.</p>
  </div>
<% end %>

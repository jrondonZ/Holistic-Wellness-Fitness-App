<% content_for :title, "Messages" %>

<div class="section-head">
  <div>
    <span class="eyebrow">Secure messaging</span>
    <h1 class="h3 mb-0">Care team</h1>
  </div>
  <span class="pill"><i class="fa-solid fa-lock me-1"></i>Private</span>
</div>

<div class="hwf-card">
  <div class="d-flex align-items-center gap-2 pb-3 mb-3 border-bottom">
    <div class="service-icon-lg" style="background: var(--brand-green); width:44px; height:44px; font-size:1.1rem;"><i class="fa-solid fa-user-nurse"></i></div>
    <div>
      <div class="fw-bold">Holistic Wellness Fitness</div>
      <div class="small text-muted">Your coach &amp; care team</div>
    </div>
  </div>

  <div class="chat-window mb-3">
    <% if @messages.any? %>
      <% @messages.each do |m| %>
        <div class="msg <%= m.from_member? ? 'out' : 'in' %>">
          <div><%= simple_format m.body, {}, sanitize: true %></div>
          <div class="meta"><%= m.from_member? ? "You" : m.sender.first_name %> · <%= m.created_at.strftime("%b %-d, %-l:%M %p") %></div>
        </div>
      <% end %>
    <% else %>
      <div class="chat-empty">
        <i class="fa-solid fa-comments d-block mb-2" style="font-size: 1.8rem; color: var(--brand-sage);"></i>
        Start the conversation — ask a question about your plan, nutrition or an appointment.
      </div>
    <% end %>
  </div>

  <%= form_with url: messages_path, method: :post, local: true do %>
    <div class="input-group">
      <%= text_field_tag "message[body]", nil, class: "form-control", placeholder: "Write a message…", autocomplete: "off", required: true %>
      <%= submit_tag "Send", class: "btn btn-brand" %>
    </div>
  <% end %>
</div>

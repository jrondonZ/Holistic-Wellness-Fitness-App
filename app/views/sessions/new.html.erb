<% content_for :title, "Log in" %>

<div class="container">
  <div class="auth-card">
    <div class="hwf-card p-4 p-md-5" data-aos="fade-up">
      <div class="text-center mb-4">
        <span class="leaf d-inline-grid mb-3" style="width:48px;height:48px;background:var(--brand-green);color:#fff;border-radius:14px;place-items:center;font-size:1.3rem;">
          <i class="fa-solid fa-leaf"></i>
        </span>
        <h1 class="h3">Welcome back</h1>
        <p class="text-muted mb-0">Open your holistic chart</p>
      </div>

      <%= form_with url: login_path, method: :post, local: true do |f| %>
        <div class="mb-3">
          <%= label_tag :username, "Username or email", class: "form-label" %>
          <%= text_field_tag :username, params[:username], class: "form-control", autofocus: true, autocomplete: "username", placeholder: "you@example.com" %>
        </div>
        <div class="mb-3">
          <%= label_tag :password, "Password", class: "form-label" %>
          <%= password_field_tag :password, nil, class: "form-control", autocomplete: "current-password", placeholder: "••••••••" %>
        </div>
        <div class="d-grid">
          <%= submit_tag "Log in", class: "btn btn-brand btn-lg" %>
        </div>
      <% end %>

      <p class="text-center text-muted mt-4 mb-0">
        New here? <%= link_to "Create your chart", signup_path, class: "fw-semibold" %>
      </p>
    </div>
  </div>
</div>

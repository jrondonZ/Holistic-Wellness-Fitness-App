<!DOCTYPE html>
<html lang="en">
  <%= render "layouts/head" %>
  <body>
    <%= render "layouts/app_navbar" %>
    <div class="chart-shell">
      <%= render "layouts/chart_sidebar" %>
      <main class="chart-main">
        <div class="flash-stack"><%= render "layouts/flash" %></div>
        <%= yield %>
      </main>
    </div>
    <%= render "layouts/sage_widget" if logged_in? && !legal_gate? %>
    <%= render "shared/legal_gate" if legal_gate? %>
  </body>
</html>

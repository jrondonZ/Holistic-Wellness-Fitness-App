<%# Sage — floating holistic-wellness assistant. Rendered for signed-in members
    on every in-chart page. Behaviour lives in the `sage` Stimulus controller
    (app/javascript/controllers/sage_controller.js) — served from our own origin,
    so it needs no inline script and complies with the app's strict CSP while
    surviving Turbo navigations. Talks to POST /api/ai/chat. %>
<div id="sage-widget"
     data-controller="sage"
     data-sage-avatar-value="/sage-mark.svg"
     data-sage-url-value="<%= api_ai_chat_path %>">
  <button class="sage-fab" type="button"
          data-sage-target="fab" data-action="sage#toggle"
          title="Ask Sage" aria-label="Ask Sage, your wellness assistant">
    <%= image_tag "/sage-mark.svg", alt: "", class: "sage-fab-mark", aria: { hidden: true } %>
  </button>

  <div class="sage-panel" data-sage-target="panel" style="display:none;">
    <div class="sage-panel-header">
      <div class="sage-panel-ident">
        <div class="sage-panel-icon"><%= image_tag "/sage-mark.svg", alt: "", class: "sage-panel-mark", aria: { hidden: true } %></div>
        <div class="sage-panel-meta">
          <span class="sage-panel-name">Sage</span>
          <span class="sage-panel-tag">Wellness companion</span>
        </div>
      </div>
      <button type="button" class="btn-close btn-close-white btn-sm"
              data-action="sage#toggle" aria-label="Close Sage"></button>
    </div>

    <div class="sage-messages" data-sage-target="messages">
      <div class="sage-msg sage-msg--bot">
        <span class="sage-msg-av" aria-hidden="true"><%= image_tag "/sage-mark.svg", alt: "", aria: { hidden: true } %></span>
        <div>
          <div class="sage-msg-bubble">
            Hi<%= current_user&.first_name.present? ? " #{current_user.first_name}" : "" %>! I&rsquo;m <strong>Sage</strong>, your holistic wellness companion. Ask me about nutrition, gut health, movement, sleep, stress&mdash;or how your chart is trending.
          </div>
          <div class="sage-suggestions">
            <button type="button" class="sage-chip" data-action="sage#suggest" data-suggestion="What should I eat after a workout?">Post-workout meal</button>
            <button type="button" class="sage-chip" data-action="sage#suggest" data-suggestion="How can I improve my sleep?">Better sleep</button>
            <button type="button" class="sage-chip" data-action="sage#suggest" data-suggestion="How am I doing on my chart?">My progress</button>
          </div>
          <p class="sage-disclaimer">Sage offers general wellness education, not medical advice.</p>
        </div>
      </div>
    </div>

    <div class="sage-input-row">
      <input type="text" class="form-control"
             data-sage-target="input" data-action="keydown->sage#keydown"
             placeholder="Ask Sage about your wellness&hellip;" maxlength="500" autocomplete="off">
      <button class="sage-send-btn" type="button"
              data-sage-target="send" data-action="sage#send" aria-label="Send message">
        <i class="fas fa-paper-plane"></i>
      </button>
    </div>
  </div>
</div>

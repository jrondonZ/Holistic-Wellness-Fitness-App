<%= javascript_tag nonce: true do %>
(function () {
  var csrf   = document.querySelector('meta[name="csrf-token"]');
  csrf = csrf ? csrf.content : "";
  var widget = document.getElementById("sage-widget");
  var fab    = document.getElementById("sage-fab");
  var panel  = document.getElementById("sage-panel");
  var closeB = document.getElementById("sage-close");
  var msgs   = document.getElementById("sage-messages");
  var input  = document.getElementById("sage-input");
  var send   = document.getElementById("sage-send");
  if (!fab || !panel) return;
  // Guard against double-binding (Turbo can re-run inline scripts).
  if (widget && widget.dataset.sageBound) return;
  if (widget) widget.dataset.sageBound = "1";
  var avSrc = (widget && widget.dataset.botAv) || "";
  var open = false, loading = false;

  var esc = function (s) {
    return String(s == null ? "" : s)
      .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  };
  var md = function (t) {
    return esc(t)
      .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
      .replace(/_(.+?)_/g, "<em>$1</em>")
      .replace(/^[-•]\s+(.+)$/gm, "<li>$1</li>")
      .replace(/^\d+\.\s+(.+)$/gm, "<li>$1</li>")
      .replace(/(<li>[\s\S]*?<\/li>\n?)+/g, function (m) {
        return '<ul class="sage-list">' + m + "</ul>";
      })
      .replace(/\n/g, "<br>");
  };
  var BOT_AV = '<span class="sage-msg-av" aria-hidden="true"><img src="' + avSrc + '" alt=""></span>';
  var append = function (text, role) {
    var d = document.createElement("div");
    d.className = "sage-msg sage-msg--" + role;
    if (role === "bot") {
      d.innerHTML = BOT_AV + '<div><div class="sage-msg-bubble">' + md(text) + "</div></div>";
    } else {
      d.innerHTML = '<div class="sage-msg-bubble">' + esc(text).replace(/\n/g, "<br>") + "</div>";
    }
    msgs.appendChild(d);
    setTimeout(function () { msgs.scrollTop = msgs.scrollHeight; }, 30);
  };
  var toggle = function () {
    open = !open;
    fab.classList.toggle("is-open", open);
    if (open) {
      panel.style.display = "flex";
      setTimeout(function () { input.focus(); }, 80);
    } else {
      panel.style.display = "none";
    }
  };
  var submit = async function () {
    var m = input.value.trim();
    if (!m || loading) return;
    append(m, "user"); input.value = ""; loading = true; send.disabled = true;
    var tid = "t" + Date.now();
    var t = document.createElement("div");
    t.className = "sage-msg sage-msg--bot"; t.id = tid;
    t.innerHTML = BOT_AV + '<div><div class="sage-msg-bubble"><span class="sage-typing"><span></span><span></span><span></span></span></div></div>';
    msgs.appendChild(t);
    setTimeout(function () { msgs.scrollTop = msgs.scrollHeight; }, 30);
    try {
      var r = await fetch("/api/ai/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json", "X-CSRF-Token": csrf },
        body: JSON.stringify({ message: m })
      });
      var d = await r.json();
      var el = document.getElementById(tid); if (el) el.remove();
      append(r.ok ? (d.reply || "") : (d.error || "Something went wrong."), "bot");
    } catch (e) {
      var el2 = document.getElementById(tid); if (el2) el2.remove();
      append("Connection trouble — please check your network and try again.", "bot");
    } finally { loading = false; send.disabled = false; }
  };

  fab.addEventListener("click", toggle);
  closeB.addEventListener("click", toggle);
  send.addEventListener("click", submit);
  input.addEventListener("keypress", function (e) {
    if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); submit(); }
  });
  msgs.querySelectorAll(".sage-chip").forEach(function (c) {
    c.addEventListener("click", function () {
      var s = c.dataset.suggestion;
      var wrap = c.closest(".sage-suggestions"); if (wrap) wrap.remove();
      input.value = s; submit();
    });
  });
})();
<% end %>
